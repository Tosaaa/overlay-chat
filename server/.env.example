# Server Port (matches docker-compose ports mapping)
PORT=8080

# Security: Allowed origin for WebSocket (e.g., https://chat.tosaaa.xyz or *)
# Desktop clients usually don't send Origin header, so this is mainly for web safety.
ALLOWED_ORIGIN=*

# Security: Shared secret between client and server
ROOM_KEY=[CHANGE_THIS_ROOM_KEY]

# Performance: Max message size in bytes
MAX_MESSAGE_BYTES=4096

# Performance: Max concurrent connections
MAX_CONNECTIONS=100
