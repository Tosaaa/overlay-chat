# Server Port
PORT=8080

# Security: Allowed origin for WebSocket
ALLOWED_ORIGIN=*

# Security: Room-specific keys (format: room1:key1,room2:key2)
# If this is set, only rooms listed here can be joined with their respective keys.
ROOM_KEYS=default:secret-key-1,secret_room:secret-key-2

# Performance: Max message size in bytes
MAX_MESSAGE_BYTES=4096

# Performance: Max concurrent connections
MAX_CONNECTIONS=100
