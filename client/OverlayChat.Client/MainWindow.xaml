<Window x:Class="OverlayChat.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Overlay Chat"
        Width="420"
        Height="300"
        MinWidth="320"
        MinHeight="220"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <Border Background="{Binding OverlayBackgroundBrush}" CornerRadius="10" Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,8" LastChildFill="False" Background="Transparent" MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="#E6FFFFFF"
                           FontWeight="SemiBold"
                           Text="Overlay Chat" />
                <Button x:Name="CloseButton"
                    DockPanel.Dock="Right"
                    Width="24"
                    Height="24"
                    Margin="8,0,0,0"
                    Background="#33FFFFFF"
                    BorderBrush="#55FFFFFF"
                    Foreground="White"
                    FontWeight="Bold"
                    Content="X"
                    Click="CloseButton_OnClick" />
                <Button x:Name="SettingsButton"
                        DockPanel.Dock="Right"
                        Width="24"
                        Height="24"
                        Margin="8,0,0,0"
                        Background="#33FFFFFF"
                        BorderBrush="#55FFFFFF"
                        Foreground="White"
                        FontWeight="Bold"
                        Content="S"
                        Click="SettingsButton_OnClick" />
                <Button x:Name="UsersButton"
                    DockPanel.Dock="Right"
                    Width="24"
                    Height="24"
                    Margin="8,0,0,0"
                    Background="#33FFFFFF"
                    BorderBrush="#55FFFFFF"
                    Foreground="White"
                    FontWeight="Bold"
                    Content="U"
                    Click="UsersButton_OnClick" />
            </DockPanel>

            <ScrollViewer x:Name="MessagesScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Foreground="{Binding DataContext.ChatTextBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                       FontSize="{Binding DataContext.ChatFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6">
                                <Run Text="[" />
                                <Run Text="{Binding Name}" FontWeight="SemiBold" />
                                <Run Text="] " />
                                <Run Text="{Binding Text}" />
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <DockPanel Grid.Row="2" LastChildFill="True" Margin="0,8,0,0">
                <TextBox x:Name="InputBox"
                         Height="30"
                         VerticalContentAlignment="Center"
                         Background="#AAFFFFFF"
                         FontSize="{Binding ChatFontSize}"
                         BorderThickness="0"
                         Padding="8,0"
                         KeyDown="InputBox_OnKeyDown" />
            </DockPanel>

            <Border Grid.RowSpan="3"
                    Width="230"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Margin="0,32,0,0"
                    Background="#EE1A1A1A"
                    BorderBrush="#66FFFFFF"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10"
                    Visibility="{Binding IsSettingsOpen, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Foreground="White" FontWeight="SemiBold" Text="Settings" />

                        <TextBlock Foreground="#E6FFFFFF" Margin="0,10,0,4" Text="Opacity" />
                        <Slider Minimum="0.3"
                            Maximum="1.0"
                            Value="{Binding OverlayOpacity, Mode=TwoWay}" />

                        <TextBlock Foreground="#E6FFFFFF" Margin="0,10,0,4" Text="Font Size" />
                        <Slider Minimum="10"
                            Maximum="28"
                            Value="{Binding ChatFontSize, Mode=TwoWay}" />

                        <TextBlock Foreground="#E6FFFFFF" Margin="0,10,0,4" Text="Text Color" />

                        <TextBlock Foreground="#CCFFFFFF" FontSize="11" Text="R" />
                        <Slider Minimum="0" Maximum="255" Value="{Binding ChatColorR, Mode=TwoWay}" />

                        <TextBlock Foreground="#CCFFFFFF" FontSize="11" Margin="0,4,0,0" Text="G" />
                        <Slider Minimum="0" Maximum="255" Value="{Binding ChatColorG, Mode=TwoWay}" />

                        <TextBlock Foreground="#CCFFFFFF" FontSize="11" Margin="0,4,0,0" Text="B" />
                        <Slider Minimum="0" Maximum="255" Value="{Binding ChatColorB, Mode=TwoWay}" />

                        <Border Margin="0,8,0,0"
                            Height="24"
                            CornerRadius="4"
                            BorderBrush="#55FFFFFF"
                            BorderThickness="1"
                            Background="{Binding ChatTextBrush}" />

                        <TextBlock Margin="0,6,0,0"
                               Foreground="#CCFFFFFF"
                               FontSize="11"
                               Text="{Binding ChatTextColorHex}" />

                            <CheckBox Margin="0,12,0,0"
                                      Foreground="#E6FFFFFF"
                                      IsChecked="{Binding FocusInputWithEnterEnabled, Mode=TwoWay}"
                                      Content="Global Enter opens chat input" />

                            <CheckBox Margin="0,8,0,0"
                                      Foreground="#E6FFFFFF"
                                      IsChecked="{Binding ClickThroughEnabled, Mode=TwoWay}"
                                      Content="Click-through mode" />

                                <CheckBox Margin="0,8,0,0"
                                      Foreground="#E6FFFFFF"
                                      IsChecked="{Binding NotificationSoundEnabled, Mode=TwoWay}"
                                      Content="Notification sound" />

                                <TextBlock Foreground="#E6FFFFFF" Margin="0,8,0,4" Text="Notification volume" />
                                <Slider Minimum="0"
                                    Maximum="1"
                                    SmallChange="0.05"
                                    TickFrequency="0.1"
                                    IsSnapToTickEnabled="False"
                                    Value="{Binding NotificationVolume, Mode=TwoWay}" />
                    </StackPanel>
                    </ScrollViewer>

                    <DockPanel Grid.Row="1" Margin="0,10,0,0" LastChildFill="False">
                    <Button Width="76"
                        Height="28"
                        Content="Save"
                        Click="SaveSettingsButton_OnClick" />
                    <Button Width="76"
                        Height="28"
                        Margin="8,0,0,0"
                        Content="Close"
                        Click="CloseSettingsButton_OnClick" />
                    </DockPanel>
                </Grid>
            </Border>

            <Border Grid.RowSpan="3"
                    Width="190"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,32,0,0"
                    Background="#EE1A1A1A"
                    BorderBrush="#66FFFFFF"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10"
                    Visibility="{Binding IsUsersOpen, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Foreground="White"
                               FontWeight="SemiBold"
                               Text="Online Users" />

                    <ListBox Grid.Row="1"
                             Margin="0,8,0,0"
                             Background="#22000000"
                             BorderBrush="#55FFFFFF"
                             Foreground="#E6FFFFFF"
                             ItemsSource="{Binding OnlineUsers}" />

                    <Button Grid.Row="2"
                            Margin="0,8,0,0"
                            Height="28"
                            Content="Close"
                            Click="CloseUsersButton_OnClick" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
